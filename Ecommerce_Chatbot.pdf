BT /F2 7 Tf 48 196 Td (    def predict\(self, sentence\):) Tj ET
BT /F2 7 Tf 48 187 Td (        tokens = tokenize\(sentence\)) Tj ET
BT /F2 7 Tf 48 178 Td (        features = bag_of_words\(tokens, self.all_words\)) Tj ET
BT /F2 7 Tf 48 169 Td (        features = features.reshape\(1, features.shape[0]\)) Tj ET
BT /F2 7 Tf 48 160 Td (        features = torch.from_numpy\(features\).to\(self.device\)) Tj ET
BT /F2 7 Tf 48 151 Td () Tj ET
BT /F2 7 Tf 48 142 Td (        with torch.no_grad\(\):) Tj ET
BT /F2 7 Tf 48 133 Td (            output = self.model\(features\)) Tj ET
BT /F2 7 Tf 48 124 Td (            _, predicted = torch.max\(output, dim=1\)) Tj ET
BT /F2 7 Tf 48 115 Td (            probs = torch.softmax\(output, dim=1\)) Tj ET
BT /F2 7 Tf 48 106 Td () Tj ET
BT /F2 7 Tf 48 97 Td (        tag = self.tags[predicted.item\(\)]) Tj ET
BT /F2 7 Tf 48 88 Td (        probability = probs[0][predicted.item\(\)].item\(\)) Tj ET
BT /F2 7 Tf 48 79 Td (        return tag, probability) Tj ET
BT /F2 7 Tf 48 70 Td () Tj ET
