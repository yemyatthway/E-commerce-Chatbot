BT /F2 7 Tf 48 262 Td (            score = math.log\(category_count / self.total_examples\)) Tj ET
BT /F2 7 Tf 48 253 Td (            denominator = self.total_tokens[category] + vocabulary_size) Tj ET
BT /F2 7 Tf 48 244 Td (            for token in tokens:) Tj ET
BT /F2 7 Tf 48 235 Td (                numerator = self.token_counts[category][token] + 1) Tj ET
BT /F2 7 Tf 48 226 Td (                score += math.log\(numerator / denominator\)) Tj ET
BT /F2 7 Tf 48 217 Td (            scores[category] = score) Tj ET
BT /F2 7 Tf 48 208 Td () Tj ET
